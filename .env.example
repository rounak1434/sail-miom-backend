# ── SAIL-MIOM Backend — environment template ──
# Copy to .env and fill in real values. NEVER commit the real .env.

PORT=5000
NODE_ENV=production
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sail_miom_db

# JWT
JWT_SECRET=<random 64-char hex>
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=<another random 64-char hex>
JWT_REFRESH_EXPIRES_IN=7d

# AWS S3 (drawing storage) — code reads AWS_S3_BUCKET (not AWS_BUCKET_NAME)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=sail-miom-drawings

# Push notifications (OneSignal)
ONESIGNAL_APP_ID=
ONESIGNAL_API_KEY=

# Email — Amazon SES SMTP (via Nodemailer). Optional: if unset, SLA-escalation
# email is skipped (push still works). Get SMTP creds from SES → SMTP settings.
SMTP_HOST=email-smtp.ap-south-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=<SES SMTP username>
SMTP_PASS=<SES SMTP password>
FROM_EMAIL=alerts@miom.sail.in
FROM_NAME=SAIL MIOM Electrical

# CORS
ALLOWED_ORIGINS=https://electrical.miom.sail.in

# Seed passwords (used by prisma/seed.js)
SEED_SUPERADMIN_PASSWORD=
SEED_ADMIN_PASSWORD=

# Rate limit (defaults: 15 min window, 1000 requests)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1000
